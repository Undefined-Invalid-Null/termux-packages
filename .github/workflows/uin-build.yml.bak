name: UIN.Tool Build

on:
  push:
    branches: [ master, main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    container:
      image: ghcr.io/termux/package-builder
      options: --user root

    strategy:
      fail-fast: false
      matrix:
        arch: [aarch64, arm, i686, x86_64]

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Debug 1 - Check container environment
        run: |
          echo "=== Current user ==="
          whoami
          echo "=== Current directory ==="
          pwd
          echo "=== List root directories ==="
          ls -la /
          echo "=== Home directory ==="
          ls -la /github/home/ 2>/dev/null || echo "No /github/home"
          echo "=== Environment variables ==="
          env | sort

      - name: Debug 2 - Find NDK location
        run: |
          echo "=== Searching for NDK ==="
          find / -name "android-ndk*" -type d 2>/dev/null | head -10
          echo "=== Searching for NDK directory ==="
          find / -name "android-ndk*" -type d -printf "%p\n" 2>/dev/null | grep -v "proc" | head -5
          echo "=== Checking common NDK paths ==="
          test -d /android-ndk && echo "FOUND: /android-ndk" || echo "NOT FOUND: /android-ndk"
          test -d /github/home/lib/android-ndk-r29 && echo "FOUND: /github/home/lib/android-ndk-r29" || echo "NOT FOUND: /github/home/lib/android-ndk-r29"
          test -d /opt/android-ndk && echo "FOUND: /opt/android-ndk" || echo "NOT FOUND: /opt/android-ndk"
          test -d /usr/local/android-ndk && echo "FOUND: /usr/local/android-ndk" || echo "NOT FOUND: /usr/local/android-ndk"

      - name: Debug 3 - Find Android SDK
        run: |
          echo "=== Searching for Android SDK ==="
          find / -name "android-sdk*" -type d 2>/dev/null | head -10
          test -d /android-sdk && echo "FOUND: /android-sdk" || echo "NOT FOUND: /android-sdk"
          test -d /github/home/lib/android-sdk-9123335 && echo "FOUND: /github/home/lib/android-sdk-9123335" || echo "NOT FOUND: /github/home/lib/android-sdk-9123335"

      - name: Debug 4 - Check original properties.sh
        run: |
          echo "=== Original TERMUX variables in properties.sh ==="
          grep -E "^(export )?TERMUX_(APP|REPO)?" scripts/properties.sh | head -20
          echo "=== NDK related lines ==="
          grep -n "NDK" scripts/properties.sh | head -10
          echo "=== ANDROID_HOME related lines ==="
          grep -n "ANDROID_HOME" scripts/properties.sh | head -10

      - name: Fix 1 - Change package name to com.UIN.Tool
        run: |
          echo "=== Changing package name ==="
          # 备份原文件
          cp scripts/properties.sh scripts/properties.sh.bak
          
          # 修改包名
          sed -i 's/TERMUX_APP__PACKAGE_NAME="com.termux"/TERMUX_APP__PACKAGE_NAME="com.UIN.Tool"/g' scripts/properties.sh
          sed -i 's/TERMUX_APP__NAMESPACE="com.termux"/TERMUX_APP__NAMESPACE="com.UIN.Tool"/g' scripts/properties.sh
          sed -i 's/TERMUX_APP_PACKAGE="com.termux"/TERMUX_APP_PACKAGE="com.UIN.Tool"/g' scripts/properties.sh
          sed -i 's/TERMUX_REPO_APP__PACKAGE_NAME="com.termux"/TERMUX_REPO_APP__PACKAGE_NAME="com.UIN.Tool"/g' scripts/properties.sh
          
          echo "=== Modified package name lines ==="
          grep -E "TERMUX.*PACKAGE" scripts/properties.sh | grep -E "com\.(UIN\.Tool|termux)"

      - name: Fix 2 - Fix NDK path in properties.sh
        run: |
          echo "=== Fixing NDK path ==="
          # 查找正确的 NDK 路径
          if [ -d "/android-ndk" ]; then
            NDK_PATH="/android-ndk"
          elif [ -d "/github/home/lib/android-ndk-r29" ]; then
            NDK_PATH="/github/home/lib/android-ndk-r29"
          elif [ -d "/opt/android-ndk" ]; then
            NDK_PATH="/opt/android-ndk"
          else
            NDK_PATH="/github/home/lib/android-ndk-r29"
          fi
          
          echo "Using NDK_PATH: $NDK_PATH"
          
          # 修改 NDK 路径
          sed -i "s|/github/home/lib/android-ndk-r29|$NDK_PATH|g" scripts/properties.sh
          sed -i "s|/github/home/lib/android-sdk-9123335|/android-sdk|g" scripts/properties.sh
          
          echo "=== Modified NDK lines ==="
          grep -n "NDK" scripts/properties.sh | head -5

      - name: Fix 3 - Add forced build settings
        run: |
          echo "=== Adding forced build settings ==="
          cat >> scripts/properties.sh << 'EOF'

# ============================================
# UIN.Tool forced build settings
# ============================================
export TERMUX_INSTALL_DEPS=true
export TERMUX_FORCE_BUILD_DEPENDENCIES=false
export TERMUX_SKIP_DEPCHECK=true
export TERMUX_WITHOUT_DEPVERSION_BINDING=true
export TERMUX_ALLOW_CROSS_REPO_DOWNLOAD=true
EOF
          
          echo "=== Settings added ==="
          tail -10 scripts/properties.sh

      - name: Fix 4 - Create NDK symlink if needed
        run: |
          echo "=== Creating NDK symlink ==="
          mkdir -p /github/home/lib
          
          if [ -d "/android-ndk" ] && [ ! -d "/github/home/lib/android-ndk-r29" ]; then
            ln -sf /android-ndk /github/home/lib/android-ndk-r29
            echo "Created symlink: /github/home/lib/android-ndk-r29 -> /android-ndk"
          elif [ -d "/opt/android-ndk" ] && [ ! -d "/github/home/lib/android-ndk-r29" ]; then
            ln -sf /opt/android-ndk /github/home/lib/android-ndk-r29
            echo "Created symlink: /github/home/lib/android-ndk-r29 -> /opt/android-ndk"
          fi
          
          echo "=== Current NDK symlink ==="
          ls -la /github/home/lib/ 2>/dev/null || echo "Cannot list /github/home/lib"

      - name: Debug 5 - Verify final properties.sh
        run: |
          echo "=== Final TERMUX variables ==="
          grep -E "^(export )?TERMUX_" scripts/properties.sh | grep -v "^#" | head -30
          echo "=== NDK variable value ==="
          grep "NDK=" scripts/properties.sh | head -3
          echo "=== ANDROID_HOME variable value ==="
          grep "ANDROID_HOME" scripts/properties.sh | head -3

      - name: Build package
        run: |
          echo "=== Starting build ==="
          echo "Architecture: ${{ matrix.arch }}"
          echo "Package: bash"
          echo "=== Build command ==="
          echo "./build-package.sh -a ${{ matrix.arch }} bash"
          echo "=== Build output ==="
          ./build-package.sh -a ${{ matrix.arch }} bash
        env:
          TERMUX_APP_PACKAGE_NAME: "com.UIN.Tool"
          TERMUX_APP_PACKAGE: "com.UIN.Tool"
          TERMUX_REPO_APP__PACKAGE_NAME: "com.UIN.Tool"
          TERMUX_INSTALL_DEPS: "true"
          TERMUX_SKIP_DEPCHECK: "true"
          TERMUX_FORCE_BUILD_DEPENDENCIES: "false"
          TERMUX_ALLOW_CROSS_REPO_DOWNLOAD: "true"
          NDK: "/android-ndk"
          ANDROID_HOME: "/android-sdk"

      - name: Debug 6 - Check build output
        if: always()
        run: |
          echo "=== Check output directory ==="
          ls -la output/ 2>/dev/null || echo "No output directory"
          echo "=== Check for .deb files ==="
          find output -name "*.deb" 2>/dev/null | head -10 || echo "No .deb files found"
          echo "=== Check for .pkg.tar files ==="
          find output -name "*.pkg.tar.*" 2>/dev/null | head -10 || echo "No .pkg.tar files found"

      - name: Upload artifacts
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: uin-tool-debs-${{ matrix.arch }}
          path: |
            output/*.deb
            output/*.pkg.tar.*
            output/*.tar.xz
          retention-days: 7
          if-no-files-found: warn

      - name: Upload debug logs on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: debug-logs-${{ matrix.arch }}
          path: |
            scripts/properties.sh
            scripts/properties.sh.bak
            output/
          retention-days: 3