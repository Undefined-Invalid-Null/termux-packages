name: UIN.Tool Build

on:
  push:
    branches: [ master ]
  workflow_dispatch:
    inputs:
      package:
        description: 'Package to build'
        required: false
        default: 'bash'
        type: string

jobs:
  build:
    runs-on: ubuntu-latest
    container:
      image: ghcr.io/termux/package-builder
      options: --user root --privileged

    steps:
      - uses: actions/checkout@v4

      - name: Configure UIN.Tool
        run: |
          # 修改包名
          sed -i 's/com.termux/com.UIN.Tool/g' scripts/properties.sh
          
          # 修正 NDK 路径
          sed -i 's|/github/home/lib/android-ndk-r29|/home/builder/lib/android-ndk-r29|g' scripts/properties.sh
          
          # 启用依赖下载
          echo "export TERMUX_INSTALL_DEPS=true" >> scripts/properties.sh
          
          # 移除有问题的链接标志
          sed -i 's/-Wl,--no-as-needed,-landroid-support,--as-needed//g' scripts/build/toolchain/termux_setup_toolchain_29.sh 2>/dev/null || true
          
          # 添加 -lc 解决 mblen 问题
          sed -i 's/export LDFLAGS="\([^"]*\)"/export LDFLAGS="\1 -lc"/g' scripts/build/toolchain/termux_setup_toolchain_29.sh 2>/dev/null || true

      - name: Build ncurses
        run: |
          export NDK=/home/builder/lib/android-ndk-r29
          export ANDROID_HOME=/home/builder/lib/android-sdk-9123335
          export TERMUX_INSTALL_DEPS=true
          ./build-package.sh -a aarch64 ncurses

      - name: Build readline
        run: |
          export NDK=/home/builder/lib/android-ndk-r29
          export ANDROID_HOME=/home/builder/lib/android-sdk-9123335
          export TERMUX_INSTALL_DEPS=true
          ./build-package.sh -a aarch64 readline

      - name: Build target package
        run: |
          export NDK=/home/builder/lib/android-ndk-r29
          export ANDROID_HOME=/home/builder/lib/android-sdk-9123335
          export TERMUX_INSTALL_DEPS=true
          ./build-package.sh -a aarch64 ${{ github.event.inputs.package || 'bash' }}

      - name: Upload artifacts
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: uin-tool-aarch64
          path: output/
          retention-days: 7